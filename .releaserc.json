{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "cd Emby.Xtream.Plugin && dotnet publish -c Release -o out --no-self-contained -p:Version=${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "Emby.Xtream.Plugin/out/Emby.Xtream.Plugin.dll",
            "label": "Emby.Xtream.Plugin.dll"
          }
        ]
      }
    ]
  ]
}
